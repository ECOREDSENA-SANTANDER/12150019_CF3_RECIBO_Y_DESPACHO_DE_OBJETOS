r","data":"base64:"},{"version":3,"names":["Actividad","name","components","data","cuestionario","tema","titulo","introduccion","titulo_aprobado","titulo_reprobado","barajarPreguntas","preguntas","id","texto","imagen","require","barajarRespuestas","opciones","esCorrecta","mensaje_correcto","mensaje_incorrecto","mensaje_final_aprobado","mensaje_final_reprobado"],"sources":["src/views/Actividad.vue"],"sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from 'ecored-pkg-fliz/plugin/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Exploración de movimientos de mercancías: ingreso y salida.',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b>Objetivo:</b> Evaluar la comprensión de los conceptos exploración de movimientos de mercancías: ingreso y salida.',\n      titulo_aprobado: '¡BUEN TRABAJO!',\n      titulo_reprobado: 'VUELVA A INTENTARLO',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            '¿Los registros de ingreso y salida de mercancías no son necesarios para la programación de despachos ni para la gestión de inventarios? ',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 2,\n          texto:\n            '¿La requisición no necesita incluir información sobre el número único asignado a la solicitud para su seguimiento?',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 3,\n          texto:\n            '¿Es cierto que la factura comercial debe incluir la fecha de la operación, los datos comerciales del vendedor y del comprador, y la información detallada de los productos? ',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 4,\n          texto:\n            '¿La remisión debe incluir la fecha de entrega, el área que entrega y recibe la mercancía, y el detalle de los productos entregados? ',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 5,\n          texto:\n            '¿La orden de compra o pedido no debe incluir especificaciones detalladas del producto, como cantidad solicitada y valor unitario? ',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 6,\n          texto:\n            '¿El listado de <em>picking</em> detalla las ubicaciones y cantidades de las referencias que deben ser alistadas para su posterior despacho? ',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 7,\n          texto:\n            '¿El registro de devolución debe incluir un informe detallado que explique las razones de la devolución de los productos? ',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 8,\n          texto:\n            '¿Las políticas de ingreso y salida de objetos aseguran que las mercancías se reciban y despachen de manera eficiente, precisa y oportuna? ',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 9,\n          texto:\n            '¿Los registros de ingreso y salida no contribuyen al control de la trazabilidad de los productos a lo largo de la cadena de suministro? ',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n        {\n          id: 10,\n          texto:\n            '¿Es cierto que el procedimiento pormenorizado no incluye el control detallado de los productos en existencia ni el registro de las mercancías adquiridas? ',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: false,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto:\n            '¡Felicitaciones! Ha captado con claridad la exploración de movimientos de mercancías: ingreso y salida. ',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo. ',\n        },\n      ],\n      mensaje_final_aprobado:\n        '¡Excelente trabajo! posee una buena comprensión sobre exploración de movimientos de mercancías: ingreso y salida. ¡Felicitaciones! Ha captado con claridad exploración de movimientos de mercancías: ingreso y salida ',\n      mensaje_final_reprobado:\n        'No ha superado la actividad. Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"],"mappings":"AAWA,OAAAA,SAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,IAAA,EAAAA,CAAA;IACAC,YAAA;MACAC,IAAA;MACAC,MAAA;MACAC,YAAA,EACA;MACAC,eAAA;MACAC,gBAAA;MACAC,gBAAA;MACAC,SAAA,GACA;QACAC,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAAA;QACAC,QAAA,GACA;UACAL,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,GACA;UACAN,EAAA;UACAC,KAAA;UACAK,UAAA;QACA,EACA;QACAC,gBAAA,EACA;QACAC,kBAAA,EACA;MACA,GACA;QACAR,EAAA;QACAC,KAAA,EACA;QACAC,MAAA,EAAAC,OAAA;QACAC,iBAA